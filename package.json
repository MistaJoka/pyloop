{
  "name": "pyloop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sync-pyodide": "node scripts/sync-pyodide.mjs",
    "verify-content": "esbuild src/content/topics/index.ts --bundle --format=esm --outfile=/tmp/pyloop-content.mjs && node scripts/verify-content.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pyodide": "^0.28.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.10"
  }
}
